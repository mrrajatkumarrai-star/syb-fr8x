{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    {
      "src": "/portal(/?)$",
      "dest": "/syb-fr8x.html"
    },
    {
      "src": "/customer-portal(/?)$",
      "dest": "/syb-fr8x.html"
    },
    {
      "src": "/syb-fr8x(/?)$",
      "dest": "/syb-fr8x.html"
    },
    {
      "src": "/erp(/?)$",
      "dest": "/freight_erp_full.html"
    },
    {
      "src": "/$",
      "dest": "/freight_erp_full.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}